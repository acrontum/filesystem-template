{
  "name": "@acrontum/filesystem-template",
  "version": "0.0.2",
  "repository": "https://github.com/acrontum/filesystem-template",
  "description": "Filesystem templating engine and project scaffolding tool",
  "main": "dist/src/index.js",
  "bin": {
    "fst": "./dist/src/cli.js"
  },
  "scripts": {
    "preinstall": "git config core.hooksPath ./hooks",
    "build": "tsc -p .",
    "watch": "tsc-watch -p . --onSuccess 'echo done'",
    "fmt": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "pretest": "rm -rf .fst test-output; [ -d dist ] || npm run build",
    "test": "FST_LOG=${FST_LOG:-error} NODE_ENV=test mocha --recursive 'dist/test/**/*.spec.js'"
  },
  "files": [
    "dist",
    "readme.md",
    "LICENSE"
  ],
  "keywords": [],
  "author": "p-mcgowan",
  "license": "MIT",
  "dependencies": {
    "fdir": "^5.1.0"
  },
  "devDependencies": {
    "@types/chai": "^4.2.21",
    "@types/mocha": "^9.0.0",
    "@types/node": "^16.7.12",
    "@types/sinon": "^10.0.2",
    "chai": "^4.3.4",
    "mocha": "^9.1.3",
    "prettier": "^2.3.2",
    "sinon": "^11.1.2",
    "source-map-support": "^0.5.19",
    "tsc-watch": "^5.0.2",
    "typescript": "^4.4.2"
  }
}
