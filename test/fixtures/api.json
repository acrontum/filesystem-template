{
  "swagger": "2.0",
  "info": {
    "description": "Historical vehicle data",
    "version": "1.0.0",
    "title": "dsd_historical_data_swagger",
    "contact": {
      "email": "info@acrontum.de"
    },
    "license": {
      "name": "private",
      "url": "https://www.acrontum.de"
    }
  },
  "schemes": [
    "http",
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json; charset=utf-8"
  ],
  "host": "bmw-dsd-historical-data-default.acs-thor.lan",
  "basePath": "/hist/",
  "securityDefinitions": {
    "jwt": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "parameters": {
    "PathVin": {
      "in": "path",
      "name": "vin",
      "type": "string",
      "description": "The VIN of the car",
      "required": true,
      "x-example": "WBACW21080LB42374"
    }
  },
  "paths": {
    "/admin/health": {
      "get": {
        "summary": "Service health check",
        "description": "Service health check",
        "responses": {
          "200": {
            "description": "Success response"
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "Admin"
        ],
        "operationId": "adminHealthGet"
      }
    },
    "/mileage/anonymize/vins": {
      "post": {
        "summary": "Anonimize vins",
        "description": "Anonimize vins\n",
        "parameters": [
          {
            "in": "body",
            "name": "mileageAnonymizeVinsPost",
            "required": true,
            "description": "Anonimize vins older than this date",
            "schema": {
              "$ref": "#/definitions/MileageHistoryAnonymizeModel"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "success"
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "Mileage"
        ],
        "operationId": "mileageAnonymizeVinsPost"
      }
    },
    "/mileage/{vin}/calculate": {
      "get": {
        "summary": "Fetch the calculated average mileage for a given vin",
        "description": "Fetch the calculated average mileage for a given vin",
        "parameters": [
          {
            "$ref": "#/parameters/PathVin"
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "schema": {
              "$ref": "#/definitions/MileageCalculateModel"
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "Mileage"
        ],
        "operationId": "mileageVinCalculateGet"
      }
    },
    "/mileage/{vin}": {
      "get": {
        "summary": "Fetch mileage for a given vin",
        "description": "Fetch mileage for a given vin",
        "parameters": [
          {
            "$ref": "#/parameters/PathVin"
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "schema": {
              "$ref": "#/definitions/MileageHistoryModel"
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "Mileage"
        ],
        "operationId": "mileageVinGet",
        "x-passResponse": true,
        "security": {
          "jwtToken": true
        }
      },
      "post": {
        "summary": "Post mileage information",
        "description": "Post mileage information",
        "parameters": [
          {
            "$ref": "#/parameters/PathVin"
          },
          {
            "in": "body",
            "name": "MileageSummary",
            "required": true,
            "description": "Summary data",
            "schema": {
              "$ref": "#/definitions/MileageHistoryModel"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "success"
          },
          "404": {
            "description": "Not found"
          }
        },
        "tags": [
          "Mileage"
        ],
        "operationId": "mileageVinPost"
      }
    }
  },
  "definitions": {
    "GenericSearchMeta": {
      "type": "object",
      "properties": {
        "resultCount": {
          "type": "number"
        },
        "offset": {
          "type": "number"
        },
        "pageLimit": {
          "type": "number"
        }
      }
    },
    "JobCode": {
      "type": "string",
      "enum": [
        "anonymize",
        "cbs",
        "ccm",
        "market_tool",
        "vehicle_mileage"
      ],
      "description": "Job code"
    },
    "JobExecutionModel": {
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "code": {
          "$ref": "#/definitions/JobCode"
        },
        "running": {
          "type": "boolean"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastSuccessAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "JobExecutionModels": {
      "type": "object",
      "properties": {
        "meta": {
          "$ref": "#/definitions/GenericSearchMeta"
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/JobExecutionModel"
          }
        }
      }
    },
    "MileageCalculateModel": {
      "type": "object",
      "required": [
        "avgMileagePerWeek"
      ],
      "properties": {
        "avgMileagePerWeek": {
          "type": "number",
          "description": "Average mileage per week"
        }
      }
    },
    "MileageHistoryAnonymizeModel": {
      "type": "object",
      "required": [
        "anonimizeOlderThan"
      ],
      "properties": {
        "anonimizeOlderThan": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "MileageHistoryModel": {
      "type": "object",
      "required": [
        "vin",
        "mileage",
        "unit",
        "avgMileagePerWeek",
        "mileageTimestamp"
      ],
      "properties": {
        "id": {
          "type": "number",
          "description": "History Id"
        },
        "vin": {
          "type": "string",
          "description": "Vin"
        },
        "mileage": {
          "type": "number",
          "description": "Vin"
        },
        "unit": {
          "type": "string",
          "description": "Mileage unit"
        },
        "avgMileagePerWeek": {
          "type": "number",
          "description": "Average mileage per week"
        },
        "mileageTimestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Real timestamp of the mileage"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "minMileage": {
          "type": "number"
        },
        "maxMileage": {
          "type": "number"
        },
        "diffMileage": {
          "type": "number"
        },
        "week": {
          "type": "number"
        }
      }
    }
  }
}